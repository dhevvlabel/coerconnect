{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "publicProfile": { "type": "boolean" },
        "sharePlans": { "type": "boolean" },
        "instagram": { "type": "string" },
        "twitter": { "type": "string" },
        "telegram": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "ConcertPlan": {
      "title": "Concert Plan",
      "description": "Detailed concert travel plan generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "city": { "type": "string" },
        "budget": { "type": "number" },
        "duration": { "type": "integer" },
        "planData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "city", "budget", "duration", "planData"]
    },
    "Like": {
      "title": "Like Action",
      "description": "Interactions between users representing connections",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["like", "pass"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages sent between mutually connected users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "matchId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["matchId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/plans/{planId}": {
      "schema": "ConcertPlan",
      "description": "Saved concert plans"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Matches and swiping logs"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages between matched Users"
    }
  }
}
