{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ConcertPlan": {
      "title": "Concert Plan",
      "description": "Detailed concert travel plan generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "city": { "type": "string" },
        "budget": { "type": "number" },
        "duration": { "type": "integer" },
        "planData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "city", "budget", "duration", "planData"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/plans/{planId}": {
      "schema": "ConcertPlan",
      "description": "Saved concert plans"
    }
  }
}
