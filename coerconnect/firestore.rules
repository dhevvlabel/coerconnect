rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['userId', 'city', 'budget', 'duration', 'planData', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.budget is number &&
             data.duration is int;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Concert plans
    match /plans/{planId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPlan(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
